generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Client {
  id             String   @id @default(uuid())
  name           String?
  hikvision_user String?
  hikvision_pass String?
  google_email   String?
  google_pass    String?
  ewelink_user   String?
  ewelink_pass   String?
  domotics_notes String?

  latitude       Float?
  longitude      Float?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Setting {
  key   String @id
  value String
}
